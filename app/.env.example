# Uvicorn settings
APP__UC__HOST=127.0.0.1
APP__UC__PORT=8000
APP__UC__RELOAD=1

# Database connection settings. Replace <username>, <password>, <host>, <port>, and <database_name>
# with the actual values of your database.
APP__DB__HOST=<host>
APP__DB__PORT=<port>
APP__DB__USER=<username>
APP__DB__PASSWORD=<password>
APP__DB__NAME=<database_name>

# SQLAlchemy settings
APP__DB__ECHO=1
APP__DB__POOL_SIZE=5
APP__DB__MAX_OVERFLOW=10
